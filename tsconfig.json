{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "./out",
        "rootDir": "./src",
        "lib": ["ES2020", "DOM"],
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": ["node", "vscode"],
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test", "out"]
}